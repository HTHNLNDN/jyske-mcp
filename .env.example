# Enable Banking API credentials
# Obtained from https://enablebanking.com — create an application to get APP_ID and private key.
ENABLE_BANKING_APP_ID=your-app-id-here
ENABLE_BANKING_PRIVATE_KEY_PATH=~/.config/mcp-bank/enablebanking_private.key
ENABLE_BANKING_REDIRECT_URL=https://your-callback-url/callback.html

# Anthropic API key
# Used by cron/sync.py for batch merchant categorization. Not used during chat — the
# chat server reads its API key from the environment directly via the anthropic SDK default.
ANTHROPIC_API_KEY=sk-ant-...

# App authentication
APP_PIN=123456
SESSION_SECRET=generate-a-long-random-hex-string-here
