# Enable Banking API credentials
# Obtained from https://enablebanking.com — create an application to get APP_ID and private key.
ENABLE_BANKING_APP_ID=your-app-id-here
ENABLE_BANKING_PRIVATE_KEY_PATH=~/.config/mcp-bank/enablebanking_private.key
# Must point at this app's own /consent/callback route (src/jyske_mcp/web/app.py), reachable
# from the internet — e.g. an ngrok/cloudflared tunnel URL such as
# https://your-tunnel-host.example/consent/callback. Also register this exact
# URL in the Enable Banking application dashboard, or the /auth call will be
# rejected.
ENABLE_BANKING_REDIRECT_URL=https://<your-tunnel-host>/consent/callback

# LLM provider, via LiteLLM (see src/jyske_mcp/llm.py) — switching models/providers is a
# one-line change here, no code changes needed.
LLM_MODEL=claude-sonnet-4-6
LLM_FALLBACK_MODEL=
# Other provider examples (uncomment to use):
# LLM_MODEL=gpt-4o
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_MODEL=deepseek/deepseek-chat
# LLM_MODEL=ollama/llama3  (requires Ollama running locally)

# Provider API keys — only the one matching LLM_MODEL needs to be set.
# ANTHROPIC_API_KEY is also used by the sync job (src/jyske_mcp/kernel/sync.py), which hardcodes a Haiku
# model for batch merchant categorization regardless of LLM_MODEL.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# App authentication
APP_PIN=123456
SESSION_SECRET=generate-a-long-random-hex-string-here

# Shared secret guarding the internal scheduler service (src/jyske_mcp/jobs/scheduler.py on
# 127.0.0.1:8081). Sent as the X-Scheduler-Secret header by jyske_mcp/kernel/consent.py.
# Do NOT reuse SESSION_SECRET. If unset, the scheduler rejects all requests.
SCHEDULER_SECRET=generate-a-long-random-hex-string-here

# Web server bind address and port (src/jyske_mcp/web/app.py)
APP_HOST=0.0.0.0
APP_PORT=8080
# Langfuse observability (self-hosted, see docker/langfuse/docker-compose.yml
# and `make langfuse`). Public/secret keys come from the Langfuse UI after
# first login — generated per-project, so they can't be pre-filled here.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_ENABLED=true

# Dev-session telemetry (Claude Code -> Langfuse, see .claude/hooks/lf_telemetry.py).
# Keys from a SEPARATE Langfuse project named "claude-dev" — keeps dev-setup
# metrics apart from the product agent's traces. Optional: hooks no-op when unset.
LANGFUSE_DEV_PUBLIC_KEY=
LANGFUSE_DEV_SECRET_KEY=
