# Langfuse self-hosted stack secrets (docker/langfuse/docker-compose.yml).
# Copy this file to docker/langfuse/.env and fill in real values — that file
# is gitignored and must never be committed.

# Auth secrets for the Langfuse web app. Generate with:
#   openssl rand -hex 32
# Docker Compose does NOT execute shell commands in YAML values, so these
# MUST be generated once here and pasted in as literal values — do not put
# `$(openssl rand -hex 32)` directly in docker-compose.yml.
NEXTAUTH_SECRET=CHANGE_ME_run_openssl_rand_-hex_32
SALT=CHANGE_ME_run_openssl_rand_-hex_32

# Postgres credentials, used by both the postgres and langfuse services.
# Pick your own values — there is no default. Postgres has no host port
# mapping, so it's only reachable from the langfuse container on the
# compose-internal network.
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=langfuse
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@postgres:5432/langfuse

# Host interface the Langfuse UI binds to (host:container is
# ${LANGFUSE_BIND_HOST}:3000:3000). 127.0.0.1 keeps it local-only; only
# widen this (e.g. to 0.0.0.0) for a genuine LAN use case.
LANGFUSE_BIND_HOST=127.0.0.1
